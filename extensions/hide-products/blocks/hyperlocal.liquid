{% schema %}
  {
    "name": "Collection Hyperlocal",
    "target": "body",
    "javascript": "hyperlocal.js",
    "settings": [
      {
        "type": "text",
        "id": "zip_code_btn",
        "label": "ZIP Code Button Text",
        "default": "Change ZIP Code"
      },
      {
        "type": "text",
        "id": "popup_header",
        "label": "Popup Header Text",
        "default": "Enter ZIP Code"
      },
      {
        "type": "text",
        "id": "placeholder_text",
        "label": "Placeholder Text",
        "default": "Enter ZIP Code"
      },
      {
        "type": "text",
        "id": "current_zip_code",
        "label": "Current ZIP Code Text",
        "default": "Current ZIP Code"
      },
      {
        "type": "text",
        "id": "hyperlocalMetaFieldKey",
        "label": "Hyperlocal Meta Field Key (deprecated)",
        "info": "No longer used. New installs use deterministic sharded keys (zips_0 … zips_31). Safe to leave blank."
      },
      {
        "type": "color",
        "id": "button_background_color",
        "label": "Button background color",
        "default": "#000"
      },
      {
        "type": "textarea",
        "id": "popup_description_text",
        "label": "Popup Description Text",
        "default": "Some products are only available in certain ZIP Locations, Please add zip code to see available products in your area"
      },
      {
        "type": "text",
        "id": "popup_logo_url",
        "label": "Popup Logo Image URL",
        "info": "URL of the logo image to display at the top of the ZIP code popup."
      },
      {
        "type": "liquid",
        "id": "customCss",
        "label": "Custom CSS",
        "info": "Add your own CSS styles. Scope them carefully to avoid affecting other elements. Eg: #zip-popup button { color: red; }",
      }
    ]
  }
{% endschema %}

{%- comment -%}
  Sharded hyperlocal embed config.
  Backend writes coverage to N parallel metafields `st_hyperlocal.zips_0` … `st_hyperlocal.zips_{N-1}`.
  Keep `st_shard_count` in sync with `config('hyperlocal.shard_count')` server-side.
  See docs/hyperlocal-proposed-solution.md (§4).
{%- endcomment -%}

{%- comment -%} Keep st_shard_count in sync with config('hyperlocal.shard_count'). {%- endcomment -%}
{%- assign st_shard_count = 8 -%}
{%- assign st_key_prefix = 'zips_' -%}
{%- assign st_shard_max = st_shard_count | minus: 1 -%}

{%- capture st_product_metafields_json -%}
  {%- if product -%}
    {
    {%- for i in (0..st_shard_max) -%}
      {%- assign key = st_key_prefix | append: i -%}
      {%- assign mf = product.metafields.st_hyperlocal[key] -%}
      {{ key | json }}: {% if mf %}{{ mf.value | json }}{% else %}[]{% endif %}{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
    }
  {%- endif -%}
{%- endcapture -%}

<script type="application/json" id="st-hyperlocal-embed-config">
{
  "shardCount": {{ st_shard_count }},
  "metafieldKeyPrefix": {{ st_key_prefix | json }},
  "isProductTemplate": {% if template.name == 'product' %}true{% else %}false{% endif %},
  {%- if product -%}
  "productMetafields": {{ st_product_metafields_json }},
  {%- endif -%}
  "zipCodeBtn": {{ block.settings.zip_code_btn | json }},
  "popupHeader": {{ block.settings.popup_header | json }},
  "placeholderText": {{ block.settings.placeholder_text | json }},
  "currentZipCode": {{ block.settings.current_zip_code | json }},
  "buttonBackgroundColor": {{ block.settings.button_background_color | json }},
  "submitLabel": "Submit",
  "introCopyProduct": {{ 'Some products are only available in certain ZIP Locations. Please add zip code to see if this product is available in your area.' | json }},
  "introCopyDefault": {{ block.settings.popup_description_text | json }},
  "popupLogoUrl": {{ block.settings.popup_logo_url | json }}
}
</script>

<style>
    /* Custom CSS from block settings */
  {% if block.settings.customCss != blank %}
    /* ===== CUSTOM CSS START ===== */
    {{ block.settings.customCss }}
    /* ===== CUSTOM CSS END ===== */
  {% endif %}
</style>
