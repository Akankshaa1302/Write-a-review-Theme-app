{% schema %}
  {
    "name": "Collection Hyperlocal",
    "target": "body",
    "javascript": "hyperlocal-min.js",
    "settings": [
      {
        "type": "text",
        "id": "zip_code_btn",
        "label": "ZIP Code Button Text",
        "default": "Change ZIP Code"
      },
      {
        "type": "text",
        "id": "popup_header",
        "label": "Popup Header Text",
        "default": "Enter ZIP Code"
      },
      {
        "type": "text",
        "id": "placeholder_text",
        "label": "Placeholder Text",
        "default": "Enter ZIP Code"
      },
      {
        "type": "text",
        "id": "current_zip_code",
        "label": "Current ZIP Code Text",
        "default": "Current ZIP Code"
      },
      {
        "type": "text",
        "id": "hyperlocalMetaFieldKey",
        "label": "Hyperlocal Meta Field Key"
      },
      {
        "type": "color",
        "id": "button_background_color",
        "label": "Button background color",
        "default": "#000"
      },
      {
        "type": "liquid",
        "id": "customCss",
        "label": "Custom CSS",
        "info": "Add your own CSS styles. Scope them carefully to avoid affecting other elements. Eg: #zip-popup button { color: red; }",
      }
    ]
  }
{% endschema %}

{% assign st_hk = block.settings.hyperlocalMetaFieldKey %}
{% assign st_mf = false %}
{% if product and st_hk != blank %}
  {% assign st_mf = product.metafields.shipturtle[st_hk] %}
{% endif %}

<script type="application/json" id="st-hyperlocal-embed-config">
{
  "hyperlocalMetaFieldKey": {{ st_hk | json }},
  "productZipCodes": {% if st_mf %}{{ st_mf.value | json }}{% else %}null{% endif %},
  "isProductTemplate": {% if template.name == 'product' %}true{% else %}false{% endif %},
  "zipCodeBtn": {{ block.settings.zip_code_btn | json }},
  "popupHeader": {{ block.settings.popup_header | json }},
  "placeholderText": {{ block.settings.placeholder_text | json }},
  "currentZipCode": {{ block.settings.current_zip_code | json }},
  "buttonBackgroundColor": {{ block.settings.button_background_color | json }},
  "submitLabel": "Submit",
  "introCopyProduct": {{ 'Some products are only available in certain ZIP Locations. Please add zip code to see if this product is available in your area.' | json }},
  "introCopyDefault": {{ 'Some products are only available in certain ZIP Locations. Please add zip code to see available products in your area.' | json }}
}
</script>

<style>
    /* Custom CSS from block settings */
  {% if block.settings.customCss != blank %}
    /* ===== CUSTOM CSS START ===== */
    {{ block.settings.customCss }}
    /* ===== CUSTOM CSS END ===== */
  {% endif %}
</style>
